# ── App ───────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true

# ── Database ──────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ads_engine
# SQLite (local dev — uncomment to use)
# DATABASE_URL=sqlite+aiosqlite:///./ads_engine.db

# ── Claude AI ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Meta (Facebook) Ads ───────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=          # Long-lived page/system user token

# ── Google Ads ────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ── Notifications ─────────────────────────────────────────
WHATSAPP_API_TOKEN=          # WhatsApp Business Cloud API bearer token
WHATSAPP_PHONE_NUMBER_ID=    # Phone number ID from Meta developer console
WHATSAPP_VERIFY_TOKEN=       # Any secret string — enter same value in Meta console

# ── Admin ─────────────────────────────────────────────────
ADMIN_EMAIL=vishnu@example.com
ADMIN_WHATSAPP=+91XXXXXXXXXX
